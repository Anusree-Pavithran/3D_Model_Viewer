<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/canvas_bg"
    android:fitsSystemWindows="true">

    <!-- Full-screen canvas where model containers are placed dynamically -->
    <FrameLayout
        android:id="@+id/modelCanvas"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Empty state shown when no models are added yet -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:alpha="0.35">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⬡"
            android:textSize="56sp"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="12dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap + to add a model"
            android:textSize="15sp"
            android:letterSpacing="0.08"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- FAB — bottom-end, always on top -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddModel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="24dp"
        android:contentDescription="Add 3D model"
        app:srcCompat="@drawable/ic_add"
        app:backgroundTint="@color/fab_bg"
        app:tint="@color/fab_icon"
        app:elevation="8dp"
        app:hoveredFocusedTranslationZ="4dp" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>