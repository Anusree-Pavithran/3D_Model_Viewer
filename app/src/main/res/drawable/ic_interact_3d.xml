<?xml version="1.0" encoding="utf-8"?>
<!--
    A simple isometric cube outline.
    Meaning is instantly clear: "interact with the 3D object".
    Nothing resembles a reset/refresh arrow.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Top face -->
    <path
        android:pathData="M12,3 L20,7.5 L12,12 L4,7.5 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#9E9AB8"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

    <!-- Left face -->
    <path
        android:pathData="M4,7.5 L4,16.5 L12,21 L12,12 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#9E9AB8"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

    <!-- Right face -->
    <path
        android:pathData="M20,7.5 L20,16.5 L12,21 L12,12 Z"
        android:fillColor="@android:color/transparent"
        android:strokeColor="#9E9AB8"
        android:strokeWidth="1.6"
        android:strokeLineJoin="round"
        android:strokeLineCap="round" />

</vector>
